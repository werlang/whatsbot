NODE_ENV=development
API_PORT=3000
WEB_PORT=80
API_URL=http://localhost:3000
WEB_URL=http://localhost
SITE_NAME=WhatsBot
APP_TIMEZONE=UTC
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_PUBLIC_PORT=3306
MYSQL_DATABASE=whatsbot
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=change-this-before-production
WHATSAPP_CLIENT_ID=main
WHATSAPP_AUTH_PATH=/app/storage/whatsapp-auth
WHATSAPP_PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
SCHEDULER_POLL_INTERVAL_MS=15000
SCHEDULER_BATCH_SIZE=5
SCHEDULER_CLAIM_TIMEOUT_MS=600000
PUPPETEER_SKIP_DOWNLOAD=true
DEV_API_PORT=3001
DEV_API_INSPECT_PORT=9230
DEV_WEB_PORT=8080
DEV_MYSQL_PUBLIC_PORT=3307
DEV_API_URL=http://localhost:3001
DEV_WEB_URL=http://localhost:8080
